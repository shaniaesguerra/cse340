<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>

        <% if (user && user.role_name === 'admin') { %>
            <p><a href="/new-category"> + Create New Category</a></p>
        <% } %>

        <ul class="categories-list">
            <% categories.forEach(category => { %>
                <li><a href="/category/<%= category.category_id %>"><%= category.category_name %></a></li>
            <% }); %>
        </ul>
    </main>
<%- include('partials/footer') %>