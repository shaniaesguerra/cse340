<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <p>Here are a few of our partner organizations:</p>
        <ul class="organizations">
            <% organizations.forEach(organization=> { %>
                <li><img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                    <a href="/organization/<%= organization.organization_id %>">
                        <%= organization.name %>
                    </a> Email: <%= organization.contact_email %>
                </li>
                <% }); %>
        </ul>
    </main>

    <%- include('partials/footer') %>